// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  phone     String
  role      UserRole
  createdAt DateTime @default(now())

  kos       Kos[]
  reviews   Review[]
  books     Book[]
}

model Kos {
  id               Int           @id @default(autoincrement())
  user_id          Int
  name             String
  address          String
  price_per_month  Int
  gender           String
  createdAt        DateTime      @default(now())

  user             User          @relation(fields: [user_id], references: [id])
  reviews          Review[]
  books            Book[]
  images           KosImage[]
  facilities       KosFacility[]
}

model Review {
  id        Int      @id @default(autoincrement())
  kos_id    Int
  user_id   Int
  comment   String
  createdAt DateTime @default(now())

  kos       Kos      @relation(fields: [kos_id], references: [id])
  user      User     @relation(fields: [user_id], references: [id])
}

model Book {
  id         Int      @id @default(autoincrement())
  kos_id     Int
  user_id    Int
  start_date DateTime
  end_date   DateTime
  status     String
  createdAt  DateTime @default(now())

  kos        Kos      @relation(fields: [kos_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])
}

model KosImage {
  id        Int      @id @default(autoincrement())
  kos_id    Int
  file      String
  createdAt DateTime @default(now())

  kos       Kos      @relation(fields: [kos_id], references: [id])
}

model KosFacility {
  id        Int      @id @default(autoincrement())
  kos_id    Int
  facility  String
  createdAt DateTime @default(now())

  kos       Kos      @relation(fields: [kos_id], references: [id])
}

enum UserRole {
  OWNER
  SOCIETY
}