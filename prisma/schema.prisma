// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  password String
  phone    String?
  role     Role

  kos      Kos[]        @relation("OwnerKos")
  reviews  Review[]
  books    Book[]
}

model Kos {
  id             Int       @id @default(autoincrement())
  user_id        Int
  name           String
  address        String
  price_per_month Float
  gender         Gender

  owner          User      @relation("OwnerKos", fields: [user_id], references: [id])
  images         KosImage[]
  facilities     KosFacility[]
  reviews        Review[]
  books          Book[]
}

model KosImage {
  id      Int   @id @default(autoincrement())
  kos_id  Int
  file    String

  kos     Kos   @relation(fields: [kos_id], references: [id])
}

model KosFacility {
  id      Int   @id @default(autoincrement())
  kos_id  Int
  facility String

  kos     Kos   @relation(fields: [kos_id], references: [id])
}

model Review {
  id      Int   @id @default(autoincrement())
  kos_id  Int
  user_id Int
  comment String
  replay String?

  kos     Kos   @relation(fields: [kos_id], references: [id])
  user    User  @relation(fields: [user_id], references: [id])
}

model Book {
  id        Int        @id @default(autoincrement())
  kos_id    Int
  user_id   Int
  start_date DateTime
  end_date   DateTime
  created_at DateTime  @default(now())
  status     BookStatus

  kos        Kos        @relation(fields: [kos_id], references: [id])
  user       User       @relation(fields: [user_id], references: [id])
}

enum Role {
  OWNER
  SOCIETY
}

enum Gender {
  MALE
  FEMALE
  ALL
}

enum BookStatus {
  PENDING
  ACCEPT
  REJECT
}